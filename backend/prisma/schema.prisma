generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model PageView {
  id        String   @id @default(uuid())
  section   String
  userAgent String?
  ip        String?
  referrer  String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum ProjectStatus {
  in_progress
  completed
  private
}

enum ProjectCategory {
  freelance
  personal
  collaborative
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  stack       String[]
  status      ProjectStatus   @default(in_progress)
  category    ProjectCategory @default(personal)
  featured    Boolean         @default(false)
  order       Int             @default(0)
  repoUrl     String?
  demoUrl     String?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
