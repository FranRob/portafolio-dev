generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model AdminUser {
  id            String   @id @default(uuid())
  email         String   @unique
  passwordHash  String
  failedAttempts Int    @default(0)
  lockedUntil   DateTime?
  lastLoginAt   DateTime?
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret String?
  createdAt    DateTime @default(now())

  refreshTokens RefreshToken[]
  auditLogs    AuditLog[]
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  adminId   String
  admin    AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([adminId])
}

model AuditLog {
  id        String    @id @default(uuid())
  action   String    // login_success, login_failed, logout, token_refresh, account_locked
  ip       String?
  userAgent String?
  details  String?   // additional context
  createdAt DateTime @default(now())
  adminId  String?
  admin    AdminUser? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([createdAt])
  @@index([action])
}

model RateLimitEntry {
  id        String   @id @default(uuid())
  key      String   @unique // ip address or email
  attempts Int      @default(0)
  firstAttempt DateTime @default(now())
  lastAttempt DateTime @default(now())
  blockedUntil DateTime?

  @@index([key])
}

model PageView {
  id        String   @id @default(uuid())
  section   String
  userAgent String?
  ip        String?
  referrer  String?
  createdAt DateTime @default(now())
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  read      Boolean  @default(false)
  category  String?  @default("leido")  // filtro: no-leido, leido, o custom
  createdAt DateTime @default(now())
}

enum ProjectStatus {
  in_progress
  completed
  private
}

enum ProjectCategory {
  freelance
  personal
  collaborative
}

model Project {
  id          String          @id @default(uuid())
  title       String
  description String
  stack       String[]
  status      ProjectStatus   @default(in_progress)
  category    ProjectCategory @default(personal)
  featured    Boolean         @default(false)
  order       Int             @default(0)
  repoUrl     String?
  demoUrl     String?
  imageUrl    String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}
